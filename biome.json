{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.css",
      "!src/**/*.d.ts",
      "examples/**/*.js",
      "examples/**/*.jsx",
      "examples/**/*.css",
      "examples/**/*.html",
      "examples/**/package.json",
      "!examples/**/.next",
      "!examples/**/node_modules",
      "!examples/**/dist",
      "tests/vitest/**/*.js",
      "package.json",
      "tsconfig.json",
      "tsconfig.build.json",
      "tsconfig.tests.json",
      "rollup.config.mjs",
      "vitest.config.mjs",
      "lint-staged.config.js",
      "biome.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConfusingVoidType": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "assist": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  }
}
